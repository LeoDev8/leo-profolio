{
  "name": "leo-profolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "db:create": "node --env-file=.env scripts/db/create-database.mjs",
    "db:migrate": "node --env-file=.env scripts/db/migrate.mjs",
    "db:seed:photos": "node --env-file=.env scripts/db/seed-photos.mjs",
    "db:seed:projects": "node --env-file=.env scripts/db/seed-projects.mjs",
    "db:setup": "npm run --env-file=.env db:create && npm run db:migrate && npm run db:seed:photos && npm run db:seed:projects",
    "db:test": "node --env-file=.env scripts/db/test_mysql_connection.mjs",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "mysql2": "^3.15.3",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
